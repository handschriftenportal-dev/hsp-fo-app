    "compression": "^1.7.4",
    "ejs": "^3.1.8",
    "eureka-js-client": "^4.5.0",
    "express": "^4.17.1",
    "http-proxy-middleware": "^2.0.3",
    "i18next": "^22.4.11",
    "i18next-fs-backend": "^2.1.1",
    "i18next-http-middleware": "^3.2.2",
    "isomorphic-unfetch": "^3.1.0",
    "nocache": "^3.0.4",
    "node-cache": "^5.1.2",
    "node-html-parser": "^6.1.5",
    "proper-url-join": "^2.1.1",
