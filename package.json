{
  "name": "hsp-fo-app",
  "version": "1.9.6",
  "description": "hsp-fo-app",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "clean": "shx rm -rf ./node_modules ./dist ./test-reports ./target",
    "fix": "npm run fix:prettier && npm run fix:eslint",
    "fix:eslint": "eslint --fix \"./{src,test}/**/*.{css,md,js,jsx,json,ts,tsx}\"",
    "fix:prettier": "prettier --write \"./{src,test,server}/**/*.{css,md,js,jsx,json,ts,tsx}\"",
    "lint": "npm run lint:eslint && npm run lint:prettier",
    "lint:eslint": "eslint \"./{src,test}/**/*\"",
    "lint:prettier": "prettier --check \"./{src,test}/**/*.{css,md,js,jsx,json,ts,tsx}\"",
    "test": "jest --clearCache && jest",
    "test:light": "jest --clearCache && jest --coverage=false",
    "build": "webpack --mode=production",
    "build:dev": "webpack --mode=development --watch",
    "dev": "nodemon ./server/start.js",
    "start": "node ./server/start.js",
    "deb": "./build-debian-package.sh",
    "publish": "echo this script is only a stub for passing ci",
    "version": "echo $npm_package_version | tr -d '\n'",
    "artefactid": "echo $npm_package_name | tr -d '\n'",
    "commit": "git-cz",
    "prepare": "husky install",
    "e2e": "wait-on http://localhost:8080 && cypress open"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/handschriftenportal-dev/hsp-fo-app.git"
  },
  "devDependencies": {
    "@commitlint/cli": "^17.4.1",
    "@commitlint/config-conventional": "^17.4.0",
    "@datapunt/matomo-tracker-js": "^0.4.0",
    "@fontsource/roboto": "^4.5.8",
    "@material-ui/core": "^4.12.0",
    "@material-ui/icons": "^4.11.3",
    "@testing-library/cypress": "^9.0.0",
    "@testing-library/react": "^12.1.2",
    "@types/css-mediaquery": "^0.1.1",
    "@types/express": "^4.17.17",
    "@types/jest": "^27.0.0",
    "@types/proper-url-join": "^2.1.1",
    "@types/react": "^17.0.13",
    "@types/react-dom": "^17.0.8",
    "@types/react-redux": "^7.1.20",
    "@types/react-router-dom": "^5.3.2",
    "@typescript-eslint/eslint-plugin": "^4.17.0",
    "@typescript-eslint/parser": "^4.17.0",
    "clsx": "^1.2.1",
    "commitizen": "^4.2.6",
    "copy-webpack-plugin": "^11.0.0",
    "css-loader": "^6.7.1",
    "css-mediaquery": "^0.1.2",
    "cypress": "^12.6.0",
    "cypress-plugin-tab": "^1.0.5",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^7.21.0",
    "eslint-config-prettier": "^8.6.0",
    "eslint-config-standard": "^16.0.2",
    "eslint-plugin-cypress": "^2.12.1",
    "eslint-plugin-import": "^2.22.1",
    "eslint-plugin-json": "^3.1.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-promise": "^4.3.1",
    "eslint-plugin-react": "^7.27.1",
    "fetch-mock": "^9.11.0",
    "hsp-fo-cms": "1.8.3",
    "hsp-fo-home": "1.7.2",
    "hsp-fo-projects": "1.9.2",
    "hsp-fo-search": "^1.8.4",
    "hsp-fo-workspace": "1.9.8",
    "hsp-web-module": "1.30.0",
    "html-webpack-plugin": "^5.5.0",
    "husky": "^8.0.0",
    "i18next-browser-languagedetector": "^6.1.2",
    "jest": "^27.0.0",
    "jest-junit": "^13.0.0",
    "nodemon": "^2.0.21",
    "prettier": "^2.8.3",
    "raw-loader": "^4.0.2",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-i18next": "^11.14.3",
    "react-redux": "^7.2.6",
